<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MegaSchoen.ViewModels"
             xmlns:models="clr-namespace:DisplayManager.Core.Models;assembly=DisplayManager.Core"
             x:Class="MegaSchoen.LayoutEditorPage"
             x:DataType="viewmodels:LayoutEditorViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,320" Padding="10" ColumnSpacing="10">

        <!-- Canvas: draggable monitor rectangles -->
        <Border Grid.Row="0" Grid.Column="0" x:Name="CanvasBorder"
                Stroke="{StaticResource Gray400}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}">
            <AbsoluteLayout x:Name="CanvasLayout" />
        </Border>

        <!-- Side panel: selection details + Advanced -->
        <ScrollView Grid.Row="0" Grid.Column="1">
            <VerticalStackLayout Spacing="8">
                <Label Text="Selected monitor" FontAttributes="Bold" FontSize="16" />
                <Label Text="No monitor selected"
                       IsVisible="{Binding HasSelection, Converter={StaticResource InvertedBoolConverter}}"
                       TextColor="{StaticResource Gray500}" />

                <VerticalStackLayout Spacing="8" IsVisible="{Binding HasSelection}">
                    <Label Text="{Binding Selected.Label}" FontSize="14" FontAttributes="Bold" />

                    <Button Text="Set as Primary"
                            Command="{Binding SetPrimaryCommand}"
                            CommandParameter="{Binding Selected}" />

                    <Label Text="Rotation" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="5">
                        <Button Text="0°"   Command="{Binding RotateCommand}" CommandParameter="0"   WidthRequest="60" />
                        <Button Text="90°"  Command="{Binding RotateCommand}" CommandParameter="90"  WidthRequest="60" />
                        <Button Text="180°" Command="{Binding RotateCommand}" CommandParameter="180" WidthRequest="60" />
                        <Button Text="270°" Command="{Binding RotateCommand}" CommandParameter="270" WidthRequest="60" />
                    </HorizontalStackLayout>

                    <!-- Advanced: resolution + refresh -->
                    <Label Text="Advanced (resolution / refresh)" FontAttributes="Bold" Margin="0,6,0,0" />
                    <Picker x:Name="ModePicker"
                            ItemsSource="{Binding AvailableModes}"
                            SelectedIndexChanged="OnModeSelected"
                            Title="Choose a supported mode">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="." Converter="{StaticResource DisplayModeConverter}" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray400}" Margin="0,4" />

                <HorizontalStackLayout Spacing="8">
                    <Switch IsToggled="{Binding SnappingEnabled}" />
                    <Label Text="Snap to edges" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Button Text="Normalize" Command="{Binding NormalizeCommand}" />
                <Button Text="Identify monitors" Clicked="OnIdentifyClicked"
                        ToolTipProperties.Text="Flash every active monitor's name on its physical screen (or double-click a monitor)" />

                <BoxView HeightRequest="1" Color="{StaticResource Gray400}" Margin="0,4" />

                <Label Text="Monitors" FontAttributes="Bold" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Picker x:Name="AddMonitorPicker" Grid.Column="0"
                            Title="Choose a monitor…"
                            ItemsSource="{Binding AddableMonitors}"
                            ToolTipProperties.Text="Pick an active display not already in this preset, then Add">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="MonitorName" x:DataType="models:SavedDisplayConfig" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                    <Button Grid.Column="1" Text="Add" WidthRequest="70" Clicked="OnAddMonitorClicked" />
                </Grid>
                <Button Text="Remove selected" Command="{Binding RemoveSelectedCommand}"
                        ToolTipProperties.Text="Remove the selected monitor (its display is disabled when the preset applies)" />
                <Button Text="Reset to saved" Clicked="OnResetClicked"
                        ToolTipProperties.Text="Discard all edits and revert to the saved preset" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom bar: status + Test / Stash / Commit -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,10,0,0" ColumnSpacing="8">
            <Label Grid.Column="0" Text="{Binding Status}" VerticalOptions="Center" LineBreakMode="WordWrap" />
            <Button Grid.Column="1" Text="Test"   Command="{Binding TestCommand}"   WidthRequest="90" />
            <Button Grid.Column="2" Text="Stash"  Command="{Binding StashCommand}"  WidthRequest="90" />
            <Button Grid.Column="3" Text="Commit" Command="{Binding CommitCommand}" WidthRequest="90"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" />
        </Grid>
    </Grid>
</ContentPage>
